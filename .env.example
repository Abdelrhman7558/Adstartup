# =======================================================================
# AdStartup Environment Configuration Guide
# =======================================================================
# Rename this file to '.env' if you are developing locally.
# If deploying to Vercel/Netlify, copy these variables to the hosting platform's Dashboard.

# 1. Supabase Configurations (Public Data)
# These are SAFE to expose to the frontend. Protection is handled via Row Level Security (RLS) policies.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-public-anon-key

# 2. Payment Gateway Configuration (If needed in future for Stripe)
# DO NOT add Secret keys with VITE_ prefix. Only publishable ones.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_1234567890

# 3. Webhook / Backend Orchestration Configurations
# Place your backend webhooks URL base if required by N8N/Make
# VITE_N8N_WEBHOOK_URL=https://n8n.your-server.com/webhook/
